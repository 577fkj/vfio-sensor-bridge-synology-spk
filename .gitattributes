# Auto detect text files and perform LF normalization
* text=auto
.gitattributes text eol=lf
.gitignore text eol=lf
*.mk text eol=lf
*.cgi text eol=lf
*.py text eol=lf
*.js text eol=lf
*.html text eol=lf
*.sh text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
strings text eol=lf
Makefile text eol=lf
PLIST text eol=lf
